{
  "name": "@webrtc-player/plugin-logger",
  "version": "1.0.0",
  "description": "Logger plugin for webrtc-player — intercepts RTC lifecycle events and reports structured logs via callback",
  "license": "MIT",
  "keywords": [
    "webrtc",
    "player",
    "logger",
    "log",
    "plugin"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@webrtc-player/core": "workspace:*"
  },
  "devDependencies": {
    "@webrtc-player/core": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
