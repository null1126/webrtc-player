{
  "name": "@webrtc-engine/plugin-performance",
  "version": "1.1.0",
  "description": "Performance monitoring plugin for WebRTC Engine — reports FPS and network stats via callback",
  "license": "MIT",
  "keywords": [
    "webrtc",
    "player",
    "performance",
    "fps",
    "stats",
    "monitor"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "peerDependencies": {
    "@webrtc-engine/core": "workspace:*"
  },
  "devDependencies": {
    "@webrtc-engine/core": "workspace:*",
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
